<?xml version="1.0" encoding="UTF-8"?>
<definitions name="MinimalService"
             targetNamespace="http://localhost:9999/soap"
             xmlns="http://schemas.xmlsoap.org/wsdl/"
             xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
             xmlns:tns="http://localhost:9999/soap"
             xmlns:xsd="http://www.w3.org/2001/XMLSchema">

    <message name="PingRequest"/>
    <message name="PingResponse">
        <part name="result" type="xsd:string"/>
    </message>

    <portType name="MinimalPortType">
        <operation name="Ping">
            <input message="tns:PingRequest"/>
            <output message="tns:PingResponse"/>
        </operation>
    </portType>

    <binding name="MinimalBinding" type="tns:MinimalPortType">
        <soap:binding style="rpc" transport="http://schemas.xmlsoap.org/soap/http"/>
        <operation name="Ping">
            <soap:operation soapAction="http://localhost:9999/soap/Ping"/>
            <input>
                <soap:body use="literal"/>
            </input>
            <output>
                <soap:body use="literal"/>
            </output>
        </operation>
    </binding>

    <service name="MinimalService">
        <port name="MinimalPort" binding="tns:MinimalBinding">
            <soap:address location="http://localhost:9999/soap"/>
        </port>
    </service>
</definitions>
